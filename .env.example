# No __pycache__ next to source (use: uv run --env-file .env  or  make api / make ui)
PYTHONDONTWRITEBYTECODE=1

# Logging: INFO (default) or DEBUG (full HyDE text, longer excerpts)
LOG_LEVEL=INFO

# --- OpenAI (chat + embeddings + vision) ---
OPENAI_API_KEY=
ANSWER_MODEL=gpt-4o
EXTRACT_MODEL=gpt-4o-mini
HYDE_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Cohere (reranker via langchain-cohere CohereRerank) ---
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# --- Gemini (native multimodal embeddings for img_vec) ---
GEMINI_API_KEY=
GEMINI_IMAGE_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_IMAGE_EMBEDDING_DIM=1536

# --- LlamaParse (LlamaIndex hosted PDF extractor; OPTIONAL) ---
# If LLAMA_CLOUD_API_KEY is set, LlamaParse becomes the PRIMARY structured
# PDF extractor (markdown + tables + figure captions per page) and
# GPT-4o-mini vision JSON is only used as a per-page fallback. If unset
# (or LlamaParse errors), the legacy PyMuPDF + GPT-4o-mini path is used.
LLAMA_CLOUD_API_KEY=
LLAMA_PARSE_RESULT_TYPE=markdown
LLAMA_PARSE_PREMIUM=false

# --- Weaviate Cloud (single collection, two named vectors: txt_vec + img_vec) ---
WEAVIATE_URL=https://xxxxxxxx.weaviate.network
WEAVIATE_API_KEY=
WEAVIATE_COLLECTION=DocPages

# --- Uploads ---
MAX_PDF_UPLOAD_MB=200

# --- Page classifier (no paid call) ---
MIN_CHARS_TEXT_ONLY=500
MIN_CHARS_KEEP_PAGE=20
PAGE_RENDER_DPI=300

# --- Retrieval / answer ---
TOP_K_TEXT=20
TOP_K_IMAGE=20
TOP_K_RERANK=6
TOP_K_VISION_IN_ANSWER=2
HYBRID_ALPHA=0.5
CONFIDENCE_THRESHOLD=0.05
# Hide citations below this Cohere rerank score from the /query response.
# The answer LLM still sees every reranked context; this only filters what
# the user sees next to the answer.
CITATION_MIN_SCORE=0.7

# --- Small-talk gate (zero API calls) ---
ENABLE_SMALLTALK=true
SMALLTALK_REPLY=Hi! I answer questions about the technical PDFs you've ingested. Try something like: 'What is the torque spec for the M8 bolt?'

# --- Semantic query cache (LangChain BaseCache + OpenAI embeddings + JSON) ---
# Hits replay the previous answer (one OpenAI embed call, nothing else).
# 0.95 = strict (close paraphrases only). Raise to 0.97 for safety-critical
# technical docs where 'M8 bolts' vs 'M8 nuts' must NOT collapse together;
# lower to ~0.88 for FAQ-style apps where paraphrasing dominates.
ENABLE_QUERY_CACHE=true
QUERY_CACHE_THRESHOLD=0.95
QUERY_CACHE_PATH=data/query_cache.json
QUERY_CACHE_MAX_ENTRIES=1000
