# --- LLM (generation) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0

# --- Text embeddings: voyage | bge | openai ---
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
VOYAGE_TEXT_MODEL=voyage-3-large
VOYAGE_CODE_MODEL=voyage-code-3
BGE_MODEL=BAAI/bge-m3
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Vision / multimodal (ColPali) ---
ENABLE_VISION=true
COLPALI_MODEL=vidore/colpali-v1.3

# --- Reranker: bge | cohere ---
RERANKER_PROVIDER=bge
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Parsing (LlamaParse) ---
LLAMA_CLOUD_API_KEY=
LLAMAPARSE_RESULT_TYPE=markdown

# --- Vector store (Weaviate) ---
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_GRPC_PORT=50051
WEAVIATE_TEXT_COLLECTION=DocChunks
WEAVIATE_VISION_COLLECTION=DocPages

# --- Graph store (Neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=2ae69940
NEO4J_PASSWORD=v6B8ulMw6Rq3B7hUGIFPuadLSjWV1qVReBu-mbUPGeU
NEO4J_DATABASE=2ae69940

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
PARENT_CHUNK_SIZE=2048

# --- Retrieval ---
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=6
CONFIDENCE_THRESHOLD=0.30

# --- Observability (LangSmith) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=advanced-rag
LANGCHAIN_TRACING_V2=false
